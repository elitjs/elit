  "scripts": {
    "build": "node ./scripts/tsup-runner.mjs",
    "dev": "node ./scripts/tsup-runner.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "node ./scripts/run-local-cli.mjs test",
    "test:run": "node ./scripts/run-local-cli.mjs test --run",
    "test:coverage": "node ./scripts/run-local-cli.mjs test --coverage",
    "test:e2e": "node ./scripts/run-local-cli.mjs test --e2e",
    "test:wapk:google-drive": "node ./scripts/run-local-cli.mjs test --run --file ./testing/unit/wapk.google-drive.integration.test.ts",
    "benchmark": "node benchmark/server-benchmark.js",
    "benchmark:router": "node benchmark/router-benchmark.js",
    "docs:dev": "npm run --prefix docs dev",
    "docs:build": "npm run --prefix docs build",
    "docs:preview": "npm run --prefix docs preview",
    "docs:deploy": "npm run docs:build && gh-pages -d docs/dist"
  },
  "keywords": [
    "dom",
    "reactive",
    "state-management",
    "ui",
    "framework",
    "typescript",
    "lightweight",
    "ssr",
    "router",
    "css-in-js",
    "virtual-scrolling",
    "hmr",
    "hot-module-replacement",
    "dev-server",
    "development",
    "websocket",
    "rest-api",
    "shared-state",
    "real-time",
    "build",
    "bundler",
    "esbuild",
    "testing",
    "test-utilities"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/d-osc/elit.git"
  },
  "bugs": {
    "url": "https://github.com/d-osc/elit/issues"
  },
  "homepage": "https://d-osc.github.io/elit/",
  "dependencies": {
    "esbuild": "^0.27.3",
    "esbuild-obfuscator-plugin": "^0.0.5",
    "open": "^11.0.0",
    "smtp-server": "^3.18.4",
    "source-map": "^0.7.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^25.0.10",
    "@types/smtp-server": "^3.5.13",
    "@types/ws": "^8.5.13",
    "copyfiles": "^2.4.1",
    "elysia": "^1.4.19",
    "terser": "^5.44.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
