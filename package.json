{
  "name": "elit",
  "version": "3.6.8",
  "description": "Optimized lightweight library for creating DOM elements with reactive state",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "browser": "dist/index.js",
  "require": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "bin": {
    "elit": "./dist/cli.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
