{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "elit": ["../../src/index.ts"],
      "elit/config": ["../../src/config.ts"]
    }
  },
  "include": ["src", "elit.config.ts"]
}
