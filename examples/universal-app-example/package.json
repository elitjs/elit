{
  "name": "example-universal-app",
  "version": "0.0.0",
  "private": true,
  "description": "Single-repo Elit example covering web, desktop, and mobile",
  "scripts": {
    "web:dev": "elit dev",
    "web:build": "elit build",
    "web:build:dev": "elit build-dev",
    "web:preview": "elit preview",
    "desktop:run": "elit desktop run",
    "desktop:smoke": "elit desktop run --mode native ./src/desktop-smoke.ts",
    "desktop:smoke:assert": "bun ./scripts/assert-desktop-smoke-interactions.ts",
    "desktop:build": "elit desktop build --mode native --out-dir ./desktop-dist",
    "mobile:init": "elit mobile init . --app-id com.elit.universalexample --app-name ElitUniversalExample --web-dir dist",
    "mobile:sync": "elit mobile sync --cwd . --web-dir dist",
    "mobile:doctor": "elit mobile doctor --cwd . --json",
    "mobile:devices:android": "elit mobile devices android --cwd . --json",
    "mobile:build:android": "elit mobile build android --cwd .",
    "mobile:run:android:auto": "bun ./scripts/run-android-auto.ts",
    "test:win": "powershell -ExecutionPolicy Bypass -File ./test-universal.ps1",
    "test:sh": "bash ./test-universal.sh"
  },
  "dependencies": {
    "elit": "^3.6.9"
  }
}
