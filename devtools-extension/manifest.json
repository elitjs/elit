{
    "manifest_version": 3,
    "name": "Elit DevTools",
    "version": "1.0.0",
    "description": "Inspect @elitjs/devtools tracked state, routers, and perf events from Chrome DevTools.",
    "permissions": ["scripting"],
    "host_permissions": ["<all_urls>"],
    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "devtools_page": "devtools.html"
}
