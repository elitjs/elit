{
  "name": "@elitjs/chokidar",
  "version": "4.0.2",
  "description": "Cross-runtime file watcher for Elit",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elitjs/elit.git",
    "directory": "packages/chokidar"
  },
  "bugs": {
    "url": "https://github.com/elitjs/elit/issues"
  },
  "homepage": "https://elitjs.github.io/elit/",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@elitjs/fs": "file:../fs",
    "@elitjs/path": "file:../path",
    "@elitjs/runtime": "file:../runtime"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
