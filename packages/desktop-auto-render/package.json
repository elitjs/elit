{
  "name": "@elitjs/desktop-auto-render",
  "version": "4.0.2",
  "description": "Auto-render helpers for Elit desktop apps",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "browser": "dist/index.iife.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.iife.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elitjs/elit.git",
    "directory": "packages/desktop-auto-render"
  },
  "bugs": {
    "url": "https://github.com/elitjs/elit/issues"
  },
  "homepage": "https://elitjs.github.io/elit/",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@elitjs/dom": "file:../dom",
    "@elitjs/render-context": "file:../render-context",
    "@elitjs/style": "file:../style"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
