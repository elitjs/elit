{
  "name": "@elitjs/test",
  "version": "4.0.1",
  "description": "Test runner, runtime, reporter, and coverage for Elit",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.mjs",
      "require": "./dist/contracts.cjs"
    },
    "./globals": {
      "types": "./src/globals.d.ts"
    }
  },
  "files": [
    "dist",
    "src/globals.d.ts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elitjs/elit.git",
    "directory": "packages/test"
  },
  "bugs": {
    "url": "https://github.com/elitjs/elit/issues"
  },
  "homepage": "https://elitjs.github.io/elit/",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@elitjs/fs": "file:../fs",
    "@elitjs/path": "file:../path"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
