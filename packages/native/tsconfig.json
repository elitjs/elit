{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "@elitjs/core": ["../core/src"],
      "@elitjs/state": ["../state/src"],
      "@elitjs/style": ["../style/src"]
    }
  },
  "include": ["src"]
}
