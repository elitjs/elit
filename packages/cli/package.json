{
  "name": "@elitjs/cli",
  "version": "4.0.0",
  "description": "Command-line interface for Elit (dev, build, preview, test, mobile, desktop, wapk, pm)",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "elit": "./dist/cli.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elitjs/elit.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/elitjs/elit/issues"
  },
  "homepage": "https://d-osc.github.io/elit/",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@elitjs/build": "file:../build",
    "@elitjs/chokidar": "file:../chokidar",
    "@elitjs/config": "file:../config",
    "@elitjs/core": "file:../core",
    "@elitjs/dev-build": "file:../dev-build",
    "@elitjs/native": "file:../native",
    "@elitjs/pm": "file:../pm",
    "@elitjs/preview-build": "file:../preview-build",
    "@elitjs/render-context": "file:../render-context",
    "@elitjs/server": "file:../server",
    "@elitjs/test": "file:../test",
    "@elitjs/wapk": "file:../wapk",
    "@elitjs/workspace-package": "file:../workspace-package"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
